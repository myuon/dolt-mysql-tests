--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

CREATE TABLE t1(c1 BIT(1) NOT NULL PRIMARY KEY, c2 BIT(1));
INSERT INTO t1 VALUES (b'0', b'1'), (b'1', b'0');

SELECT HEX(c1), HEX(c2) FROM t1 ORDER BY c1;

UPDATE t1 SET c2=b'1' WHERE c1=b'1';
DELETE FROM t1 WHERE c1=b'0';

SELECT HEX(c1), HEX(c2) FROM t1 ORDER BY c1;
DROP TABLE t1;
