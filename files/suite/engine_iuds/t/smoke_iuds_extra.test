--disable_warnings
DROP TABLE IF EXISTS t_smoke;
--enable_warnings

CREATE TABLE t_smoke(id INT PRIMARY KEY, v INT);
INSERT INTO t_smoke VALUES (1, 10), (2, 20), (3, 30);

UPDATE t_smoke SET v = v + 1 WHERE id >= 2;
DELETE FROM t_smoke WHERE id = 1;

SELECT * FROM t_smoke ORDER BY id;
DROP TABLE t_smoke;
