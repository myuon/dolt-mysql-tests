--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

CREATE TABLE t1(c1 DECIMAL(10,2) NOT NULL PRIMARY KEY, c2 DECIMAL(10,2));
INSERT INTO t1 VALUES (10.00, 1.50), (20.00, 2.50), (30.00, NULL);

SELECT * FROM t1 ORDER BY c1;

UPDATE t1 SET c2 = c1 + 0.25 WHERE c2 IS NOT NULL;
DELETE FROM t1 WHERE c1 = 20.00;

SELECT * FROM t1 ORDER BY c1;
DROP TABLE t1;
