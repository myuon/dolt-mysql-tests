DROP TABLE IF EXISTS t1;
CREATE TABLE t1(a INT PRIMARY KEY, b INT);
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30);
UPDATE t1 SET b = b + 5 WHERE a >= 2 ORDER BY a;
SELECT * FROM t1 ORDER BY a;
a	b
1	10
2	25
3	35
DELETE FROM t1 WHERE b >= 25 ORDER BY a;
SELECT * FROM t1 ORDER BY a;
a	b
1	10
DROP TABLE t1;
