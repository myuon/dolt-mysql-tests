DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c1 TIME NOT NULL PRIMARY KEY, c2 TIME NULL);
INSERT INTO t1 VALUES ('00:00:10','00:00:11'), ('01:02:03', NULL), ('10:11:12','10:11:13');
SELECT * FROM t1 ORDER BY c1;
c1	c2
00:00:10	00:00:11
01:02:03	NULL
10:11:12	10:11:13
UPDATE t1 SET c2='23:59:59' WHERE c1='01:02:03';
DELETE FROM t1 WHERE c1='00:00:10';
SELECT * FROM t1 ORDER BY c1;
c1	c2
01:02:03	23:59:59
10:11:12	10:11:13
DROP TABLE t1;
