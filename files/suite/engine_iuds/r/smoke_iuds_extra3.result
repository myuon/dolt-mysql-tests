DROP TABLE IF EXISTS t_smoke3;
CREATE TABLE t_smoke3(id INT PRIMARY KEY, n DECIMAL(6,2));
INSERT INTO t_smoke3 VALUES (1, 1.00), (2, 2.50), (3, 3.75);
UPDATE t_smoke3 SET n = n * 2 WHERE id IN (2,3);
DELETE FROM t_smoke3 WHERE id = 1;
SELECT * FROM t_smoke3 ORDER BY id;
id	n
2	5.00
3	7.50
DROP TABLE t_smoke3;
