DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c1 VARCHAR(20) CHARACTER SET utf8mb4 NOT NULL PRIMARY KEY, c2 TEXT CHARACTER SET utf8mb4);
INSERT INTO t1 VALUES ('a', 'alpha'), ('あ', 'ひらがな'), ('漢', 'kanji');
SELECT * FROM t1 ORDER BY c1;
c1	c2
a	alpha
あ	ひらがな
漢	kanji
UPDATE t1 SET c2='updated' WHERE c1='あ';
DELETE FROM t1 WHERE c1='a';
SELECT * FROM t1 ORDER BY c1;
c1	c2
あ	updated
漢	kanji
DROP TABLE t1;
